# 实验名称：用于区分不同的实验运行
BOTR_EXPERIMENT_NAME=cachexl

# 批次大小：每个批次包含的样本数量 (论文: 8)
BOTR_BATCH_SIZE=8

# 最大轮数：Reflector反思的最大轮次
BOTR_MAX_ROUNDS=1

# 数据集过滤器：指定要运行的数据集名称（如 gpqa, mmlu），留空则运行所有
BOTR_DATASET_FILTER=

# 并发数：同时进行的 API 请求数量
BOTR_CONCURRENCY=4

# 断点续跑：是否跳过已完成的批次（true/false）
BOTR_RESUME=true

# 样本数量限制：每个数据集运行的最大样本数（0表示无限制，运行所有）
BOTR_LIMIT=0

# 是否随机打乱样本
BOTR_SHUFFLE=true

# 随机种子：用于样本打乱 (论文: 42)
BOTR_SEED=42

# 模型后端：使用的模型名称
# 论文中使用的模型:
#   - Qwen3-80B: qwen/qwen3-next-80b-a3b-instruct
#   - Qwen2.5-7B: qwen/qwen2.5-7b-instruct
#   - Qwen2.5-32B: qwen/qwen2.5-32b-instruct
#   - Llama-3.3-70B: meta/llama-3.3-70b-instruct
#   - DeepSeek-V3: deepseek/deepseek-v3
BOTR_MODEL_BACKEND=meta/llama-3.3-70b-instruct

# 模型温度：控制生成随机性 (论文: 0.1)
BOTR_MODEL_TEMPERATURE=0.1

# 随机种子：固定种子以保证实验结果可复现 (论文: 42)
BOTR_MODEL_SEED=42

# API 基础地址：LLM 服务提供商的 API URL
BOTR_MODEL_BASE_URL=https://integrate.api.nvidia.com/v1

# API 密钥：LLM 服务的访问密钥
LLM_API_KEY=your_api_key_here

# HTTP 超时时间（秒）：API 请求的等待超时时间
LLM_HTTP_TIMEOUT=120

# API 重试次数：请求失败后的最大重试次数
LLM_RETRY_ATTEMPTS=2

# 重试退避因子（秒）：控制重试等待时间的增长倍数
LLM_RETRY_BACKOFF=1.0

# 升级阈值 τ_l：当 Actor 和 Reflector 置信度都低于此值时触发 Escalator (论文: 0.5)
BOTR_TAU_L=0.5

# 缓存准入阈值 τ_h：缓存条目需要的最低置信度 (论文: 0.8)
BOTR_TAU_H=0.8

# 缓存容量：证据缓存的最大条目数 (论文: 100)
BOTR_CACHE_CAPACITY=100

# 检索参数
BOTR_RETRIEVAL_TOP_K=2
BOTR_RETRIEVAL_THRESHOLD=0.8

# Embedding 模型配置
EMBEDDING_BASE_URL=https://integrate.api.nvidia.com/v1
EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5
